# ==========================================
# ROOMPLAN SCANNER GLOBAL CONFIGURATION
# ==========================================

# ------------------------------------------
# MARK: - [SERVER]
# Node.js Backend Configuration
# ------------------------------------------
# The port on which the server will listen
SERVER_PORT=3001

# The directory where uploaded files will be saved (relative to the /server folder)
SERVER_UPLOAD_DIR=uploads

# Maximum file upload size (in Megabytes)
SERVER_MAX_FILE_SIZE_MB=100


# ------------------------------------------
# MARK: - [MOBILE APP] 
# React Native / Expo Configuration
# ------------------------------------------

# The URL of the server the app will connect to.
EXPO_PUBLIC_API_URL=http://192.168.1.XXX:3001

# --- Geolocation Fallback (e.g., London, UK) ---
# Used to calculate sun position if GPS is unavailable
EXPO_PUBLIC_FALLBACK_LATITUDE=51.5072
EXPO_PUBLIC_FALLBACK_LONGITUDE=0.1276